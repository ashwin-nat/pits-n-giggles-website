---
import type { CollectionEntry } from 'astro:content';
import FAQAccordion from './FAQAccordion.astro';

interface Props {
  category: string;
  entries: CollectionEntry<'faq'>[];
}

const { category, entries } = Astro.props;
const categoryId = category.toLowerCase().replace(/[\s/]+/g, '-');
---

<section id={categoryId} class="faq-category mb-10 scroll-mt-24">
  <div class="mb-4 flex items-center gap-3">
    <h2 class="text-xl font-bold text-white">{category}</h2>
    <span class="rounded-full bg-secondary-800 px-2.5 py-0.5 text-xs text-secondary-400">
      {entries.length}
    </span>
  </div>

  <div class="rounded-xl border border-secondary-800 bg-secondary-900/50 backdrop-blur-sm overflow-hidden">
    {entries.map(entry => <FAQAccordion entry={entry} />)}
  </div>
</section>
