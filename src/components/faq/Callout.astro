---
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'error';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info:    { border: 'border-accent-500/40',   bg: 'bg-accent-950/40',   icon: 'bi-info-circle-fill',    text: 'text-accent-300' },
  tip:     { border: 'border-success-500/40',  bg: 'bg-green-950/40',    icon: 'bi-lightbulb-fill',      text: 'text-green-300'  },
  warning: { border: 'border-warning-500/40',  bg: 'bg-yellow-950/40',   icon: 'bi-exclamation-triangle-fill', text: 'text-yellow-300' },
  error:   { border: 'border-error-500/40',    bg: 'bg-red-950/40',      icon: 'bi-x-circle-fill',       text: 'text-red-300'    },
};

const s = styles[type];
---

<div class={`my-4 rounded-lg border ${s.border} ${s.bg} p-4`}>
  <div class={`flex items-start gap-3 ${s.text}`}>
    <i class={`bi ${s.icon} mt-0.5 shrink-0 text-base`}></i>
    <div class="min-w-0 flex-1">
      {title && <p class="mb-1 font-semibold">{title}</p>}
      <div class="text-sm text-secondary-200 [&_a]:text-accent-400 [&_a:hover]:underline [&_code]:rounded [&_code]:bg-secondary-800 [&_code]:px-1 [&_code]:py-0.5 [&_code]:text-xs">
        <slot />
      </div>
    </div>
  </div>
</div>
